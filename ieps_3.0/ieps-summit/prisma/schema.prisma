// IEPS 3.0 — Prisma schema
// Database: Neon PostgreSQL (serverless). Set DATABASE_URL in .env.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// 1. User (admin only — attendees live in Registration)
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String // bcrypt hashed
  name      String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
}

// 2. Registration (every attendee who signs up)
model Registration {
  id              String             @id @default(cuid())
  fullName        String
  email           String             @unique
  phone           String
  institution     String
  department      String
  level           String // 100L, 200L, etc.
  role            AttendeeRole       @default(STUDENT)
  sessionInterest SessionInterest[]
  gender          String
  heardAboutUs    String
  status          RegistrationStatus @default(CONFIRMED)
  attended        Boolean            @default(false)
  certificateUrl  String?
  certificateSent Boolean            @default(false)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([status])
  @@index([createdAt])
}

// 3. SessionInterest (registration <-> session join)
model SessionInterest {
  id             String       @id @default(cuid())
  registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  registrationId String
  sessionName    String

  @@index([registrationId])
}

// 4. AnalyticsEvent (page views, registrations, certificate downloads, ...)
model AnalyticsEvent {
  id        String   @id @default(cuid())
  type      String // "PAGE_VIEW" | "REGISTRATION" | "CERTIFICATE_DOWNLOAD"
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([type])
  @@index([createdAt])
}

enum Role {
  ADMIN
  SUPER_ADMIN
  REGISTRATION // Registration team: attendance + read-only registrations only
}

enum AttendeeRole {
  STUDENT
  LECTURER
  PARLIAMENTARIAN
  PRESS
  GUEST
}

enum RegistrationStatus {
  PENDING
  CONFIRMED
  CANCELLED
}
