# ─────────────────────────────────────────────────────────────
# IEPS 3.0 — environment variables
# Copy this file to ".env" and fill in real values.
# ─────────────────────────────────────────────────────────────

# Database — Neon PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth / Auth.js v5
# Generate a secret with:  openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="http://localhost:3000"
# Auth.js v5 also reads these aliases (kept in sync with the two above):
AUTH_SECRET="your-secret-here"
AUTH_URL="http://localhost:3000"

# Email (SMTP via Nodemailer)
# Example below is Gmail. For Gmail you MUST use an "App Password"
# (Google Account → Security → 2-Step Verification → App passwords),
# not your normal account password.
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="465"
SMTP_SECURE="true"            # true for port 465 (implicit TLS), false for 587 (STARTTLS)
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
# Sender shown to recipients. Defaults to SMTP_USER if unset.
EMAIL_FROM="IEPS 3.0 <your@gmail.com>"

# Cloudinary (certificate PDF hosting)
# Either set CLOUDINARY_URL, or the three individual values below.
# If unset, certificates are served from the app's own /api/certificate/[id].
CLOUDINARY_URL="cloudinary://API_KEY:API_SECRET@CLOUD_NAME"
# CLOUDINARY_CLOUD_NAME="your-cloud-name"
# CLOUDINARY_API_KEY="your-api-key"
# CLOUDINARY_API_SECRET="your-api-secret"

# Public base URL (used to build certificate download links in emails)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Admin seed account (used by `npm run db:seed`)
ADMIN_EMAIL="tijaniremilekun9@gmail.com"
ADMIN_PASSWORD="changeme_before_deploy"
